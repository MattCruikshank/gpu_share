[configuration]
entry_symbol = "gpu_share_init"
compatibility_minimum = "4.3"

[libraries]
linux.debug.x86_64 = "res://bin/libgpu_share.linux.template_debug.x86_64.so"
linux.release.x86_64 = "res://bin/libgpu_share.linux.template_release.x86_64.so"
windows.debug.x86_64 = "res://bin/gpu_share.windows.template_debug.x86_64.dll"
windows.release.x86_64 = "res://bin/gpu_share.windows.template_release.x86_64.dll"
